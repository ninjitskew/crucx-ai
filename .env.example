# Google Apps Script URL for waitlist form submissions
# See GOOGLE_SHEETS_SETUP.md for setup instructions
NEXT_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Supabase (free tier — Mumbai region)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (build scripts) — never exposed to client
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay (test mode by default)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
NEXT_PUBLIC_RAZORPAY_LIVE=false
NEXT_PUBLIC_RAZORPAY_KEY_ID_LIVE=
